# SpriteForge environment variables.
# Copy to `.env.local` and fill in to enable login + the 3-day export trial.
# Leave NEXT_PUBLIC_AUTH_ENABLED unset to run fully open (no login, export for all).

# Turn the login / export gate on. Set to "true" ONLY when the DB + JWT vars
# below are also configured — the server only enforces auth when all are present.
NEXT_PUBLIC_AUTH_ENABLED=

# Self-hosted MySQL (server-only; never exposed to the client bundle).
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=spriteforge

# Session JWT signing secret (server-only). Use a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET=
