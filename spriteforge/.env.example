# SpriteForge environment variables.
# Copy to `.env.local` and fill in to enable login + the 3-day export trial.
# Leave everything unset to run fully open (no login, export available to all).

# Turn the client-side login/export gate on. Set to "true" ONLY when both Clerk
# keys below are also configured — all three must be set together.
NEXT_PUBLIC_AUTH_ENABLED=

# Clerk (https://dashboard.clerk.com → API Keys). Free up to 10k MAU.
# Publishable key is client-visible; secret key is server-only (never exposed).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
